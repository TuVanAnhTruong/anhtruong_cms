@model CMS.Data.Entities.Post

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thêm bài viết mới";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">
                <i class="bi bi-file-earmark-plus"></i>
                THÊM BÀI VIẾT MỚI
            </h4>
        </div>

        <div class="card-body">

            <form asp-action="Create"
                  method="post"
                  enctype="multipart/form-data">

                <div class="row">

                    <!-- Nội dung -->
                    <div class="col-md-8">

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                Tiêu đề bài viết
                            </label>

                            <input asp-for="Title"
                                   class="form-control"
                                   placeholder="Nhập tiêu đề..." />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                Nội dung bài viết
                            </label>

                            <textarea asp-for="Content"
                                      id="editor"
                                      class="form-control"
                                      rows="12"></textarea>
                        </div>

                    </div>

                    <!-- Bên phải -->
                    <div class="col-md-4">

                        <div class="mb-3">

                            <label class="form-label fw-bold">
                                Chuyên mục
                            </label>

                            <select asp-for="CategoryId"
                                    asp-items="ViewBag.CategoryList"
                                    class="form-select">

                                <option value="">-- Chọn danh mục --</option>

                            </select>

                        </div>

                        <div class="mb-3">

                            <label class="form-label fw-bold">
                                Ảnh đại diện
                            </label>

                            <input type="file"
                                   name="uploadImage"
                                   class="form-control"
                                   accept="image/*" />

                        </div>

                        <div class="mb-3">

                            <label class="form-label fw-bold">
                                Ngày đăng
                            </label>

                            <input asp-for="CreatedDate"
                                   type="date"
                                   class="form-control"
                                   value="@DateTime.Now.ToString("yyyy-MM-dd")" />

                        </div>

                        <hr />

                        <div class="d-grid gap-2">

                            <button class="btn btn-success"
                                    type="submit">

                                <i class="bi bi-cloud-upload"></i>

                                Lưu bài viết

                            </button>

                            <a asp-action="Index"
                               class="btn btn-secondary">

                                Quay lại

                            </a>

                        </div>

                    </div>

                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {

    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>

    <script>

        ClassicEditor
        .create(document.querySelector('#editor'))
        .catch(error=>{
            console.error(error);
        });

    </script>

}